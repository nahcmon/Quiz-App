{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --include=dev --workspaces --include-workspace-root",
  "buildCommand": "npm run build -w @quiz/web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
